        "partitions": [
          {
            "name": "META_2020",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Fonte = Excel.Workbook(File.Contents(\"C:\\Users\\erickss\\Downloads\\3_MODULO++-+POWER_BI+-+Expert+Sênior_VENDAS\\3_MODULO  - POWER_BI - Expert Sênior\\3_CONTROLE DE VENDAS\\meta_2020.xlsx\"), null, true),",
                "    Planilha1_Sheet = Fonte{[Item=\"Planilha1\",Kind=\"Sheet\"]}[Data],",
                "    #\"Cabeçalhos Promovidos\" = Table.PromoteHeaders(Planilha1_Sheet, [PromoteAllScalars=true]),",
                "    #\"Tipo Alterado\" = Table.TransformColumnTypes(#\"Cabeçalhos Promovidos\",{{\"DATA\", type date}, {\"TOTAL_VENDA\", Int64.Type}, {\"CAIXA_VENDEDOR\", type text}, {\"COD_FORMA_PGTO\", type text}, {\"VALOR_CANCELADO\", Int64.Type}, {\"NUMERO_CUPOM_FISCAL\", Int64.Type}}),",
                "    #\"Tipo Alterado1\" = Table.TransformColumnTypes(#\"Tipo Alterado\",{{\"NUMERO_CUPOM_FISCAL\", type text}}),",
                "    #\"Coluna Duplicada\" = Table.DuplicateColumn(#\"Tipo Alterado1\", \"NUMERO_CUPOM_FISCAL\", \"NUMERO_CUPOM_FISCAL - Copiar\"),",
                "    #\"Personalização Adicionada\" = Table.AddColumn(#\"Coluna Duplicada\", \"Personalizar\", each Text.PadStart([NUMERO_CUPOM_FISCAL],9,\"0\")),",
                "    #\"Colunas Removidas\" = Table.RemoveColumns(#\"Personalização Adicionada\",{\"Personalizar\", \"NUMERO_CUPOM_FISCAL - Copiar\"}),",
                "    #\"Colunas Reordenadas\" = Table.ReorderColumns(#\"Colunas Removidas\",{\"DATA\", \"TOTAL_VENDA\", \"VALOR_CANCELADO\", \"CAIXA_VENDEDOR\", \"NUMERO_CUPOM_FISCAL\", \"COD_FORMA_PGTO\"}),",
                "    #\"DEPARA NOME VENDEDOR 2020\" = Table.AddColumn(#\"Colunas Reordenadas\", \"NOME VENDEDOR\", each if Text.Contains([CAIXA_VENDEDOR], \"POP\") then \"PAULO\" else if Text.Contains([CAIXA_VENDEDOR], \"UFG\") then \"LEONARDO\" else if Text.Contains([CAIXA_VENDEDOR], \"TYT\") then \"YOLANDA\" else if Text.Contains([CAIXA_VENDEDOR], \"BIP\") then \"BRUNO\" else if Text.Contains([CAIXA_VENDEDOR], \"SMP\") then \"SAMIRA\" else if Text.Contains([CAIXA_VENDEDOR], \"PML\") then \"LUCAS\" else if Text.Contains([CAIXA_VENDEDOR], \"MTT\") then \"ATHEUS\" else if Text.Contains([CAIXA_VENDEDOR], \"LEL\") then \"LURDES\" else if Text.Contains([CAIXA_VENDEDOR], \"DRT\") then \"DARIO\" else if Text.Contains([CAIXA_VENDEDOR], \"TDY\") then \"TELMA\" else if Text.Contains([CAIXA_VENDEDOR], \"PEK\") then \"SAMANTA\" else null),",
                "    #\"Tipo Alterado2\" = Table.TransformColumnTypes(#\"DEPARA NOME VENDEDOR 2020\",{{\"NOME VENDEDOR\", type text}}),",
                "    #\"Colunas Reordenadas1\" = Table.ReorderColumns(#\"Tipo Alterado2\",{\"DATA\", \"TOTAL_VENDA\", \"VALOR_CANCELADO\", \"NOME VENDEDOR\", \"CAIXA_VENDEDOR\", \"NUMERO_CUPOM_FISCAL\", \"COD_FORMA_PGTO\"}),",
                "    #\"Colunas Removidas1\" = Table.RemoveColumns(#\"Colunas Reordenadas1\",{\"CAIXA_VENDEDOR\"}),",
                "    #\"DEPARA FORMA PGTO\" = Table.AddColumn(#\"Colunas Removidas1\", \"FORMA PAGAMENTO\", each if Text.Contains([COD_FORMA_PGTO], \"1\") then \"DINHEIRO\" else if Text.Contains([COD_FORMA_PGTO], \"3\") then \"CARTÃO DÉBITO\" else if Text.Contains([COD_FORMA_PGTO], \"4\") then \"CARTÃO CRÉDITO\" else if Text.Contains([COD_FORMA_PGTO], \"##\") then \"CARTÃO PRESENTE\" else if Text.Contains([COD_FORMA_PGTO], \"$$\") then \"NÃO INFORMADO\" else if Text.Contains([COD_FORMA_PGTO], \"px\") then \"PIX\" else if Text.Contains([COD_FORMA_PGTO], \"PIX\") then \"PIX\" else \"PGTO NÃO CADASTRADO\"),",
                "    #\"Colunas Removidas2\" = Table.RemoveColumns(#\"DEPARA FORMA PGTO\",{\"COD_FORMA_PGTO\"}),",
                "    #\"Tipo Alterado3\" = Table.TransformColumnTypes(#\"Colunas Removidas2\",{{\"FORMA PAGAMENTO\", type text}}),",
                "    #\"Colunas Renomeadas\" = Table.RenameColumns(#\"Tipo Alterado3\",{{\"NUMERO_CUPOM_FISCAL\", \"NUMERO_CUPOM_FISCAL\"}})",
                "in",
                "    #\"Colunas Renomeadas\""
              ],
              "type": "m"
            }
          }
        ]
