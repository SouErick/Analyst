          {
            "name": "META_2017",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Fonte = Excel.Workbook(File.Contents(\"C:\\Users\\erickss\\Downloads\\3_MODULO++-+POWER_BI+-+Expert+Sênior_VENDAS\\3_MODULO  - POWER_BI - Expert Sênior\\3_CONTROLE DE VENDAS\\4_1_meta_2017.xlsx\"), null, true),",
                "    META_2017_Sheet = Fonte{[Item=\"META_2017\",Kind=\"Sheet\"]}[Data],",
                "    #\"Cabeçalhos Promovidos\" = Table.PromoteHeaders(META_2017_Sheet, [PromoteAllScalars=true]),",
                "    #\"Tipo Alterado\" = Table.TransformColumnTypes(#\"Cabeçalhos Promovidos\",{{\"DATA\", type datetime}, {\"TOTAL_VENDA\", Int64.Type}, {\"CAIXA_VENDEDOR\", type text}, {\"COD_FORMA_PGTO\", type text}, {\"VALOR_CANCELADO\", type number}, {\"NUMERO_CUPOM_FISCAL\", Int64.Type}}),",
                "    #\"Tipo Alterado1\" = Table.TransformColumnTypes(#\"Tipo Alterado\",{{\"NUMERO_CUPOM_FISCAL\", type text}}),",
                "    #\"DEPARA VENDEDOR\" = Table.AddColumn(#\"Tipo Alterado1\", \"NOME VENDEDOR\", each if Text.Contains([CAIXA_VENDEDOR], \"UGB\") then \"UMBERTO\" else if Text.Contains([CAIXA_VENDEDOR], \"8080\") then \"NATALIA\" else if Text.Contains([CAIXA_VENDEDOR], \"WAO\") then \"WAGNER\" else if Text.Contains([CAIXA_VENDEDOR], \"WAP\") then \"LUCIA\" else \"VENDEDOR NÃO CADASTRADO\"),",
                "    #\"Tipo Alterado2\" = Table.TransformColumnTypes(#\"DEPARA VENDEDOR\",{{\"NOME VENDEDOR\", type text}}),",
                "    #\"DEPARA PAGAMENTO\" = Table.AddColumn(#\"Tipo Alterado2\", \"FORMA PAGAMENTO\", each if Text.Contains([COD_FORMA_PGTO], \"1\") then \"DINHEIRO\" else if Text.Contains([COD_FORMA_PGTO], \"3\") then \"CARTÃO DÉBITO\" else if Text.Contains([COD_FORMA_PGTO], \"4\") then \"CARTÃO CRÉDITO\" else if Text.Contains([COD_FORMA_PGTO], \"##\") then \"CARTÃO PRESENTE\" else if Text.Contains([COD_FORMA_PGTO], \"$$\") then \"NÃO INFORMADO\" else if Text.Contains([COD_FORMA_PGTO], \"px\") then \"PIX\" else \"PGTO NÃO CADASTRADO\"),",
                "    #\"Outras Colunas Removidas\" = Table.SelectColumns(#\"DEPARA PAGAMENTO\",{\"DATA\", \"TOTAL_VENDA\", \"VALOR_CANCELADO\", \"NUMERO_CUPOM_FISCAL\", \"NOME VENDEDOR\", \"FORMA PAGAMENTO\"}),",
                "    #\"Tipo Alterado3\" = Table.TransformColumnTypes(#\"Outras Colunas Removidas\",{{\"DATA\", type date}, {\"FORMA PAGAMENTO\", type text}})",
                "in",
                "    #\"Tipo Alterado3\""
              ],
              "type": "m"
            }
          }
        ]
